#include <AccelStepper.h>
#include <math.h>

// ===================== Pins =====================
static const uint8_t EN_PIN = 8;   // active-low enable on most DRV8825 carriers

static const uint8_t STEP1 = 3;
static const uint8_t DIR1  = 2;

static const uint8_t STEP2 = 5;
static const uint8_t DIR2  = 4;

static const uint8_t STEP3 = 7;
static const uint8_t DIR3  = 6;

// Stepper 4 pins (your current)
static const uint8_t STEP4 = 9;
static const uint8_t DIR4  = 12;

// ===================== Steppers =====================
AccelStepper s1(AccelStepper::DRIVER, STEP1, DIR1);
AccelStepper s2(AccelStepper::DRIVER, STEP2, DIR2);
AccelStepper s3(AccelStepper::DRIVER, STEP3, DIR3);
AccelStepper s4(AccelStepper::DRIVER, STEP4, DIR4);

// ===================== Enable helper =====================
static inline void set_enable(bool en) {
  digitalWrite(EN_PIN, en ? LOW : HIGH);  // LOW = enabled
}

// ===================== Serial line buffer =====================
static const size_t CMD_BUF_SZ = 96;
static char   cmd_buf[CMD_BUF_SZ];
static size_t cmd_len = 0;

// ===================== Safety =====================
static unsigned long last_cmd_ms = 0;
static const unsigned long CMD_TIMEOUT_MS = 250;   // stop if no valid command in 0.25s
static bool drivers_enabled = false;

// Tune motion here
static const float MAX_SPEED = 150.0f;  // steps/s
static const float ACCEL     = 60.0f;  // steps/s^2

// Optional: stop motors + disable drivers on comms timeout
static const bool DISABLE_ON_TIMEOUT = false;

// ===================== Continuum-arm model params =====================
// These should match your physical geometry + spool scaling.
// In your older sketch you used:
//   STEPS_PER_REV = 200
//   D = 0.9
//   RADIUS = 2.1
//
// Here: AT alpha_deg theta_deg -> tendon motor targets for s1,s2,s3.
//
// NOTE: If your motor drivers are microstepping, set STEPS_PER_REV_EFFECTIVE accordingly.
// Example: 200 steps/rev * 16 microsteps = 3200.
static const float STEPS_PER_REV_EFFECTIVE = 200.0f;  // <-- set this to what you actually use
static const float D = 0.9f;                          // tendon offset distance (same units as RADIUS)
static const float RADIUS = 2.1f;                     // backbone radius / effective radius
static const float THETA_OFFSET_DEG = 30.0f;          // matches your Arduino "+30" in theta

// Direction flips (very common). If bending is “mirrored” or backwards, toggle these.
// Flip all 3 tendon directions:
static const bool INVERT_TENDONS_123 = false;

// If only one tendon is reversed, you can set per-motor inversions:
static const bool INV1 = false;
static const bool INV2 = false;
static const bool INV3 = false;

// Optional clamp on alpha (safety), same as your prior sketch:
static const float ALPHA_MIN_DEG = 0.0f;
static const float ALPHA_MAX_DEG = 260.0f;

// ===================== Math helpers =====================
static inline float wrap_0_360(float deg) {
  while (deg >= 360.0f) deg -= 360.0f;
  while (deg < 0.0f) deg += 360.0f;
  return deg;
}

static inline float clampf(float v, float lo, float hi) {
  if (v < lo) return lo;
  if (v > hi) return hi;
  return v;
}

static inline long apply_inv(long v, bool inv) {
  return inv ? -v : v;
}

// Convert (alpha_deg, theta_deg) into tendon *revolutions* phi[3],
// following your prior alphaThetaToPhi() exactly:
//   phi[i] = -(alpha_rad * d / r) * cos(theta_rad + 2*pi/3*i) / (2*pi)
// but with the same +30deg theta offset.
static void alphaThetaToPhi(float alpha_deg, float theta_deg, float d, float r, float phi_out[3]) {
  const float alpha_rad = alpha_deg * (float)M_PI / 180.0f;
  float theta_rad = (theta_deg + THETA_OFFSET_DEG) * (float)M_PI / 180.0f;

  // Tendons at 0, 120, 240 deg
  phi_out[0] = -(alpha_rad * d / r) * cosf(theta_rad);
  phi_out[1] = -(alpha_rad * d / r) * cosf(theta_rad + 2.0f * (float)M_PI / 3.0f);
  phi_out[2] = -(alpha_rad * d / r) * cosf(theta_rad + 4.0f * (float)M_PI / 3.0f);

  // Convert radians-ish term into revolutions
  // (matches your prior: phi[i] /= (2*PI))
  const float inv_2pi = 1.0f / (2.0f * (float)M_PI);
  phi_out[0] *= inv_2pi;
  phi_out[1] *= inv_2pi;
  phi_out[2] *= inv_2pi;
}

static void moveMotorsToAlphaTheta(float alpha_deg, float theta_deg) {
  // Clamp/wrap like your joystick logic
  alpha_deg = clampf(alpha_deg, ALPHA_MIN_DEG, ALPHA_MAX_DEG);
  theta_deg = wrap_0_360(theta_deg);

  float phi[3];
  alphaThetaToPhi(alpha_deg, theta_deg, D, RADIUS, phi);

  long t1 = lroundf(phi[0] * STEPS_PER_REV_EFFECTIVE);
  long t2 = lroundf(phi[1] * STEPS_PER_REV_EFFECTIVE);
  long t3 = lroundf(phi[2] * STEPS_PER_REV_EFFECTIVE);

  if (INVERT_TENDONS_123) { t1 = -t1; t2 = -t2; t3 = -t3; }
  t1 = apply_inv(t1, INV1);
  t2 = apply_inv(t2, INV2);
  t3 = apply_inv(t3, INV3);

  s1.moveTo(t1);
  s2.moveTo(t2);
  s3.moveTo(t3);
}

// ===================== Command handling =====================
void handle_line(const char* line_in) {
  // Trim leading spaces
  while (*line_in == ' ' || *line_in == '\t') ++line_in;
  if (*line_in == '\0') return;

  // Enable/disable commands (optional)
  if (strcmp(line_in, "EN 1") == 0) {
    set_enable(true);
    drivers_enabled = true;
    Serial.println("ENABLED");
    return;
  }
  if (strcmp(line_in, "EN 0") == 0) {
    set_enable(false);
    drivers_enabled = false;
    Serial.println("DISABLED");
    return;
  }

  // Option 1 primary command: AT alpha_deg theta_deg
  float alpha_deg, theta_deg;
  if (sscanf(line_in, "AT %f %f", &alpha_deg, &theta_deg) == 2) {
    if (!drivers_enabled) {
      set_enable(true);
      drivers_enabled = true;
      Serial.println("AUTO-EN");
    }
    Serial.print("GOT AT: ");
Serial.print(alpha_deg, 2);
Serial.print(" ");
Serial.println(theta_deg, 2);

    last_cmd_ms = millis();

    moveMotorsToAlphaTheta(alpha_deg, theta_deg);
    return;
  }

  // Optional: separate command for stepper4: Z t4
  long z;
  if (sscanf(line_in, "Z %ld", &z) == 1) {
    if (!drivers_enabled) {
      set_enable(true);
      drivers_enabled = true;
      Serial.println("AUTO-EN");
    }
    last_cmd_ms = millis();

    s4.moveTo(z);
    return;
  }

  // Legacy/raw command still supported: P t1 t2 t3 t4
  long t1, t2, t3, t4;
  if (sscanf(line_in, "P %ld %ld %ld %ld", &t1, &t2, &t3, &t4) == 4) {
    if (!drivers_enabled) {
      set_enable(true);
      drivers_enabled = true;
      Serial.println("AUTO-EN");
    }
    last_cmd_ms = millis();

    s1.moveTo(t1);
    s2.moveTo(t2);
    s3.moveTo(t3);
    s4.moveTo(t4);
    return;
  }

  // Unknown command -> ignore silently
}

// ===================== Setup =====================
void setup() {
  // Make STEP/DIR outputs immediately to reduce floating/noise
  pinMode(STEP1, OUTPUT); pinMode(DIR1, OUTPUT);
  pinMode(STEP2, OUTPUT); pinMode(DIR2, OUTPUT);
  pinMode(STEP3, OUTPUT); pinMode(DIR3, OUTPUT);
  pinMode(STEP4, OUTPUT); pinMode(DIR4, OUTPUT);

  // IMPORTANT: disable drivers at boot (prevents runaways during reset)
  pinMode(EN_PIN, OUTPUT);
  set_enable(false);
  drivers_enabled = false;

  // Serial
  Serial.begin(115200);
  Serial.setTimeout(1);

  // Configure steppers
  s1.setMaxSpeed(MAX_SPEED); s1.setAcceleration(ACCEL);
  s2.setMaxSpeed(MAX_SPEED); s2.setAcceleration(ACCEL);
  s3.setMaxSpeed(MAX_SPEED); s3.setAcceleration(ACCEL);
  s4.setMaxSpeed(MAX_SPEED); s4.setAcceleration(ACCEL);

  s1.setCurrentPosition(0);
  s2.setCurrentPosition(0);
  s3.setCurrentPosition(0);
  s4.setCurrentPosition(0);

  last_cmd_ms = millis();

  Serial.println("READY (drivers disabled until first valid command: AT / P / Z)");
  Serial.print("STEPS_PER_REV_EFFECTIVE="); Serial.println(STEPS_PER_REV_EFFECTIVE, 0);
}

// ===================== Loop =====================
void loop() {
  // ---- 1) Read all available serial bytes (non-blocking) ----
  while (Serial.available() > 0) {
    int c = Serial.read();
    if (c < 0) break;

    if (c == '\r') continue;

    if (c == '\n') {
      if (cmd_len > 0) {
        cmd_buf[cmd_len] = '\0';
        handle_line(cmd_buf);
        cmd_len = 0;
      }
    } else {
      if (cmd_len < CMD_BUF_SZ - 1) {
        cmd_buf[cmd_len++] = (char)c;
      } else {
        cmd_len = 0; // overflow -> reset
      }
    }
  }

  // ---- 2) Watchdog: if comms stop, stop motion ----
  if (drivers_enabled && (millis() - last_cmd_ms > CMD_TIMEOUT_MS)) {
    s1.stop(); s2.stop(); s3.stop(); s4.stop();

    if (DISABLE_ON_TIMEOUT) {
      set_enable(false);
      drivers_enabled = false;
      Serial.println("TIMEOUT -> DISABLE");
    } else {
      last_cmd_ms = millis(); // prevent repeated stop spam
    }
  }

  // ---- 3) Step motors ----
  s1.run();
  s2.run();
  s3.run();
  s4.run();
}
